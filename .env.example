# Environment Configuration
MODEL_NAME=EleutherAI/gpt-j-6B
QUANTIZED=true
DEVICE=auto

# Model Parameters
MAX_LENGTH=512
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=50
REPETITION_PENALTY=1.1

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Model Cache
MODEL_CACHE_DIR=./model_cache
USE_CACHE=true

# Training
BATCH_SIZE=1
LEARNING_RATE=5e-5
NUM_EPOCHS=3
GRADIENT_ACCUMULATION_STEPS=4
SAVE_STEPS=100

# Advanced Features
ENABLE_STREAMING=true
MAX_CONVERSATION_HISTORY=10
ENABLE_CONTEXT_MEMORY=true
